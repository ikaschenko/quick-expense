GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/callback
# Google API key (Browser API key from Google Cloud Console, with Picker API enabled)
GOOGLE_API_KEY=your-google-api-key
FRONTEND_BASE_URL=http://localhost:5173
PORT=3001
SESSION_SECRET=replace-with-random-secret
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quickexpense
# Posthog analytics (leave blank to disable)
VITE_POSTHOG_KEY=
# Number of months of recent expense data loaded immediately (Phase 1).
# Older records are fetched in the background after the UI is ready.
# Default: 24 (two full years). Increase for users with very active older data.
# EXPENSE_RECENT_MONTHS=24
